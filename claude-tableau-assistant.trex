<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.anthropic.claude.dashboard-assistant" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name">Claude AI Assistant</name>
    <description>Ask Claude questions about your dashboard data</description>
    <author name="Anthropic" email="support@anthropic.com" organization="Anthropic" website="https://anthropic.com"/>
    <min-api-version>1.4</min-api-version>
    <permissions>
      <permission>full data</permission>
    </permissions>
    <source-location>
      <url>https://tyme-global-technologies.github.io/claude-tableau-extension/</url>
    </source-location>
    <icon></icon>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Claude AI Assistant</text>
    </resource>
  </resources>
</manifest>
